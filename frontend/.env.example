# ── Nuxt Frontend Configuration ──────────────────────────

# The base URL for your Laravel API (e.g., http://localhost:8000)
NUXT_PUBLIC_API_BASE=http://localhost:8000

# The key used to store the auth token in localStorage (astfisc_auth)
NUXT_PUBLIC_AUTH_STORAGE_KEY=astfisc_auth

# The key used to store the user's theme preference (light/dark)
NUXT_PUBLIC_THEME_STORAGE_KEY=astfisc_theme

# How many days a user session should remain valid
NUXT_PUBLIC_SESSION_MAX_AGE_DAYS=7

# The name of the application displayed in the UI
NUXT_PUBLIC_APP_NAME=AST-FISC
